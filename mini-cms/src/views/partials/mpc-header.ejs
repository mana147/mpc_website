<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'vi' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'MPC Port' %> | MPC Port</title>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link rel="stylesheet" href="/vendor/font-awesome/css/all.min.css">
  <link rel="stylesheet" href="/css/mpc-base.css">
  <link rel="stylesheet" href="/css/mpc-header.css">
  <link rel="stylesheet" href="/css/mpc-footer.css">
  <% if (typeof pageCss !== 'undefined' && pageCss) { %>
    <link rel="stylesheet" href="<%= pageCss %>">
  <% } %>
</head>
<body class="mpc-page">
  <!-- MPC Header -->
  <header class="mpc-header">
    <div class="header-container">
      <div class="header-logo">
        <a href="/"><img src="/images/logo.png" alt="MPC Logo" class="logo-image"></a>
      </div>

      <button class="mobile-menu-toggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="header-nav">
        <ul class="nav-menu">
          <% if (typeof visibleMenus !== 'undefined' && visibleMenus.length > 0) { %>
            <% const homeMenu = visibleMenus.find(menu => menu.slug === '/'); %>
            <% if (homeMenu) { %>
              <li><a href="<%= homeMenu.url || homeMenu.slug %>" class="<%= (typeof currentPath !== 'undefined' && currentPath === '/') ? 'active' : '' %>"><%= (typeof lang !== 'undefined' && lang === 'en' && homeMenu.name_en) ? homeMenu.name_en.toUpperCase() : homeMenu.name_vi.toUpperCase() %></a></li>
            <% } %>
            <li><a href="/about" class="<%= (typeof currentPath !== 'undefined' && currentPath === '/about') ? 'active' : '' %>"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'ABOUT MPC' : 'VỀ MPC' %></a></li>
            <% visibleMenus.forEach(menu => { %>
              <% if (menu.slug === '/') return; %>
              <%
                const menuName = (typeof lang !== 'undefined' && lang === 'en' && menu.name_en)
                  ? menu.name_en
                  : menu.name_vi;
                const menuUrl = menu.url || menu.slug;
                const hasChildren = menu.type === 'post_list' && menu.children && menu.children.length > 0;
                const isActive = (typeof currentPath !== 'undefined') && currentPath === menuUrl;
              %>
              <% if (hasChildren) { %>
                <li class="menu-item">
                  <a href="javascript:void(0)" style="color: #ffffff;"<%- isActive ? ' class="active"' : '' %>><%= menuName.toUpperCase() %></a>
                  <ul class="sub-menu">
                    <% menu.children.forEach(child => { %>
                      <%
                        const childTitle = (typeof lang !== 'undefined' && lang === 'en' && child.title_en)
                          ? child.title_en
                          : child.title;
                      %>
                      <li><a href="/posts/<%= child.slug %>"><%= childTitle %></a></li>
                    <% }) %>
                  </ul>
                </li>
              <% } else { %>
                <li><a href="<%= menuUrl %>"<%- isActive ? ' class="active"' : '' %>><%= menuName.toUpperCase() %></a></li>
              <% } %>
            <% }) %>
          <% } else { %>
            <li><a href="/" class="<%= (typeof currentPath !== 'undefined' && currentPath === '/') ? 'active' : '' %>"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'HOME' : 'TRANG CHỦ' %></a></li>
            <li><a href="/about" class="<%= (typeof currentPath !== 'undefined' && currentPath === '/about') ? 'active' : '' %>"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'ABOUT MPC' : 'VỀ MPC' %></a></li>
            <li><a href="/posts"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'POSTS' : 'BÀI VIẾT' %></a></li>
            <li><a href="/gallery"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'GALLERY' : 'THƯ VIỆN ẢNH' %></a></li>
            <li><a href="/documents"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'DOCUMENTS' : 'TÀI LIỆU' %></a></li>
            <li><a href="/contact"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'CONTACT' : 'LIÊN HỆ' %></a></li>
          <% } %>
        </ul>
      </nav>

      <% if (typeof lang !== 'undefined' && lang === 'en') { %>
        <a href="/lang/vi" class="header-language">
          <img src="/images/icons/en.png" alt="EN" class="flag-icon">
          <span>ENG</span>
          <span class="dropdown-icon">▼</span>
        </a>
      <% } else { %>
        <a href="/lang/en" class="header-language">
          <img src="/images/icons/vn.png" alt="VN" class="flag-icon">
          <span>VIE</span>
          <span class="dropdown-icon">▼</span>
        </a>
      <% } %>
    </div>
  </header>

  <main>
