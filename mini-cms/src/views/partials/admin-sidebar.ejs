<!-- Admin Sidebar Partial -->
<aside class="admin-sidebar">
  <div class="sidebar-header">
    <a href="/admin" class="sidebar-logo">Mini CMS</a>
  </div>
  <nav class="sidebar-nav">
    <a href="/admin" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">📊 Dashboard</a>
    <a href="/admin/posts" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'posts' ? 'active' : '' %>">📝 Bài viết</a>
    <a href="/admin/documents" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'documents' ? 'active' : '' %>">📄 Tài liệu</a>
    <a href="/admin/gallery" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'gallery' ? 'active' : '' %>">🖼️ Thư viện ảnh</a>
    <a href="/admin/contacts" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'contacts' ? 'active' : '' %>">📬 Liên hệ</a>
    <a href="/admin/menus" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'menus' ? 'active' : '' %>">📋 Quản lý Menu</a>
    <hr>
    <a href="/" class="nav-item" target="_blank">🌐 Xem website</a>
    <form action="/admin/logout" method="POST" style="margin: 0;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="nav-item nav-logout">🚪 Đăng xuất</button>
    </form>
  </nav>
</aside>
