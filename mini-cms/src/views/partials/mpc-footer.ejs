</main>

<!-- MPC Footer -->
<footer class="mpc-footer">
  <div class="footer-main">
    <div class="footer-container">
      <!-- Logo & Description -->
      <div class="footer-column footer-about">
        <div class="footer-logo">
          <a href="/"><img src="/images/logo.png" alt="MPC Logo" width="80" height="80"></a>
        </div>
        <p class="footer-description">
          <%= typeof t !=='undefined' && t.footer && t.footer.description ? t.footer.description
            : 'Công ty cổ phần cảng MPEC (tên giao dịch MPC) là nhà khai thác Bến cảng MPC Port.' %>
        </p>
        <div class="footer-social">
          <span>
            <%= typeof t !=='undefined' && t.footer && t.footer.connect ? t.footer.connect : 'Kết nối với chúng tôi' %>
          </span>
          <div class="social-icons">
            <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
            <a href="#" aria-label="Messenger"><i class="bi bi-messenger"></i></a>
            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
            <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
          </div>
        </div>
      </div>

      <!-- Menu Column 1 -->
      <div class="footer-column">
        <h4 class="footer-title">
          <%= typeof t !=='undefined' && t.footer && t.footer.category ? t.footer.category : 'Danh mục' %>
        </h4>
        <ul class="footer-menu">
          <% if (typeof visibleMenus !=='undefined' && visibleMenus.length> 0) { %>
            <% visibleMenus.slice(0, 4).forEach(menu=> { %>
              <% const fMenuName=(typeof lang !=='undefined' && lang==='en' && menu.name_en) ? menu.name_en :
                menu.name_vi; const fMenuUrl=menu.url || menu.slug; %>
                <li><a href="<%= fMenuUrl %>">
                    <%= fMenuName %>
                  </a></li>
                <% }) %>
                  <% } else { %>
                    <li><a href="/">Trang chủ</a></li>
                    <li><a href="/posts">Bài viết</a></li>
                    <li><a href="/gallery">Thư viện ảnh</a></li>
                    <li><a href="/documents">Tài liệu</a></li>
                    <% } %>
        </ul>
      </div>

      <!-- Menu Column 2 -->
      <div class="footer-column">
        <h4 class="footer-title">
          <%= typeof t !=='undefined' && t.footer && t.footer.category ? t.footer.category : 'Danh mục' %>
        </h4>
        <ul class="footer-menu">
          <% if (typeof visibleMenus !=='undefined' && visibleMenus.length> 4) { %>
            <% visibleMenus.slice(4).forEach(menu=> { %>
              <% const fMenuName2=(typeof lang !=='undefined' && lang==='en' && menu.name_en) ? menu.name_en :
                menu.name_vi; const fMenuUrl2=menu.url || menu.slug; %>
                <li><a href="<%= fMenuUrl2 %>">
                    <%= fMenuName2 %>
                  </a></li>
                <% }) %>
                  <% } else { %>
                    <li><a href="/contact">Liên hệ</a></li>
                    <% } %>
        </ul>
      </div>

      <!-- Contact Column -->
      <div class="footer-column footer-contact">
        <h4 class="footer-title">
          <%= typeof t !=='undefined' && t.footer && t.footer.contact_title ? t.footer.contact_title : 'Liên hệ' %>
        </h4>
        <ul class="footer-contact-list">
          <li>
            <i class="bi bi-telephone-fill"></i>
            <span>02253 280 038</span>
          </li>
          <li>
            <i class="bi bi-envelope-fill"></i>
            <span>info@mpcport.com</span>
          </li>
          <li>
            <i class="bi bi-geo-alt-fill"></i>
            <span>Bán đảo Đình Vũ, Khu KT Đình Vũ Cát Hải, Phường Đông Hải 2, Quận Hải An, Hải Phòng</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="footer-bottom">
    <div class="footer-container">
      <p class="copyright">Copyright &copy; <%= new Date().getFullYear() %> MPCPORT. All Rights Reserved. Powered by
          MPCPORT</p>
      <p class="design-credit">Design by Bizfly.vn - VCCorp | Development by Phạm Trung Hiếu </p>
      <!-- <p class="design-credit">Development by Phạm Trung Hiếu </p> -->
    </div>
  </div>
</footer>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<% if (typeof pageJs !=='undefined' && pageJs) { %>
  <script src="<%= pageJs %>"></script>
  <% } %>
    </body>

    </html>