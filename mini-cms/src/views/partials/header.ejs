<!-- Header Partial -->
<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'vi' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Mini CMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">Mini CMS</a>
      <nav class="main-nav">
        <a href="/"><%= typeof t !== 'undefined' ? t.nav.home : 'Trang chủ' %></a>
        <a href="/posts"><%= typeof t !== 'undefined' ? t.nav.posts : 'Bài viết' %></a>
        <a href="/gallery"><%= typeof t !== 'undefined' ? t.nav.gallery : 'Thư viện ảnh' %></a>
        <a href="/documents"><%= typeof t !== 'undefined' ? t.nav.documents : 'Tài liệu' %></a>
        <a href="/contact"><%= typeof t !== 'undefined' ? t.nav.contact : 'Liên hệ' %></a>
        <span class="lang-switcher">
          <a href="/lang/vi" class="<%= (typeof lang !== 'undefined' && lang === 'vi') ? 'active' : '' %>">🇻🇳 VI</a>
          <a href="/lang/en" class="<%= (typeof lang !== 'undefined' && lang === 'en') ? 'active' : '' %>">🇺🇸 EN</a>
        </span>
      </nav>
    </div>
  </header>
  <main class="main-content">
    <div class="container">
