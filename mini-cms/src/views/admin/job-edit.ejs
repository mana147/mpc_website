<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Mini CMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page">
  <% const activePage = 'jobs'; %>
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar', { activePage }) %>

    <main class="admin-main">
      <header class="admin-header">
        <h1><%= title %></h1>
        <a href="/admin/jobs" class="btn">← Quay lại</a>
      </header>

      <div class="admin-content">
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form action="/admin/jobs/<%= job.id %>/edit" method="POST" enctype="multipart/form-data" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <fieldset class="lang-fieldset">
            <legend>🇻🇳 Nội dung Tiếng Việt</legend>

            <div class="form-group">
              <label for="title">Tiêu đề *</label>
              <input type="text" id="title" name="title" required value="<%= job.title %>">
            </div>

            <div class="form-group">
              <label for="content">Mô tả công việc</label>
              <textarea id="content" name="content" rows="12"><%= job.content || '' %></textarea>
            </div>
          </fieldset>

          <fieldset class="lang-fieldset">
            <legend>🇺🇸 English Content</legend>

            <div class="form-group">
              <label for="title_en">Title (English)</label>
              <input type="text" id="title_en" name="title_en" value="<%= job.title_en || '' %>">
            </div>

            <div class="form-group">
              <label for="content_en">Job Description (English)</label>
              <textarea id="content_en" name="content_en" rows="12"><%= job.content_en || '' %></textarea>
            </div>
          </fieldset>

          <div class="form-group">
            <label for="salary">Mức lương</label>
            <input type="text" id="salary" name="salary" value="<%= job.salary || '' %>"
              placeholder="Ví dụ: 15-25 triệu hoặc Thỏa thuận">
          </div>

          <div class="form-group">
            <label for="hiring_count">Số lượng tuyển</label>
            <input type="number" id="hiring_count" name="hiring_count" min="1" value="<%= job.hiring_count || 1 %>">
          </div>

          <div class="form-group">
            <label for="deadline">Hạn nộp hồ sơ</label>
            <input type="text" id="deadline" name="deadline" value="<%= job.deadline || '' %>"
              placeholder="Ví dụ: 30/09/2024">
          </div>

          <div class="form-group">
            <label for="thumbnail">Ảnh đại diện</label>
            <% if (job.thumbnail) { %>
              <div class="current-thumbnail">
                <img src="<%= job.thumbnail %>" alt="Ảnh hiện tại">
                <p>Ảnh hiện tại. Upload ảnh mới để thay thế.</p>
              </div>
            <% } %>
            <input type="file" id="thumbnail" name="thumbnail" accept="image/jpeg,image/png,image/webp">
            <small>Chỉ chấp nhận: JPG, JPEG, PNG, WEBP. Tối đa 5MB.</small>
          </div>

          <div class="form-group">
            <label for="status">Trạng thái</label>
            <select id="status" name="status">
              <option value="draft" <%= job.status === 'draft' ? 'selected' : '' %>>Nháp (chưa hiển thị)</option>
              <option value="published" <%= job.status === 'published' ? 'selected' : '' %>>Đã đăng</option>
            </select>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a href="/admin/jobs" class="btn">Hủy</a>
          </div>
        </form>
      </div>
    </main>
  </div>
</body>
</html>
