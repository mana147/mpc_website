<%- include('../partials/mpc-header') %>

<section class="contact-hero">
  <h1><%= typeof t !== 'undefined' ? t.contact.title : 'THÔNG TIN CỦA QUÝ KHÁCH' %></h1>
  <p><%= typeof t !== 'undefined' ? t.contact.subtitle : 'Hãy để lại thông tin, chúng tôi sẽ liên hệ sớm nhất' %></p>
</section>

<div class="contact-container">
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/contact" method="POST" class="contact-form">
    <!-- Họ & Tên - Full width -->
    <div class="form-group full-width">
      <label for="full_name"><%= typeof t !== 'undefined' ? t.contact.full_name : 'Họ & Tên' %> *</label>
      <input 
        type="text" 
        id="full_name" 
        name="full_name" 
        value="<%= formData.full_name || '' %>"
        placeholder="<%= typeof t !== 'undefined' ? t.contact.full_name_placeholder : 'Nhập họ và tên của bạn' %>"
        class="<%= errors.full_name ? 'input-error' : '' %>"
      >
      <% if (errors.full_name) { %>
        <span class="error-text"><%= errors.full_name %></span>
      <% } %>
    </div>

    <!-- Email - Full width -->
    <div class="form-group full-width">
      <label for="email"><%= typeof t !== 'undefined' ? t.contact.email : 'Địa chỉ email' %> *</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        value="<%= formData.email || '' %>"
        placeholder="<%= typeof t !== 'undefined' ? t.contact.email_placeholder : 'Nhập địa chỉ email' %>"
        class="<%= errors.email ? 'input-error' : '' %>"
      >
      <% if (errors.email) { %>
        <span class="error-text"><%= errors.email %></span>
      <% } %>
    </div>

    <!-- Row: Tiêu đề + Số điện thoại -->
    <div class="form-row">
      <div class="form-group">
        <label for="subject"><%= typeof t !== 'undefined' ? t.contact.subject : 'Tiêu đề' %> *</label>
        <input 
          type="text" 
          id="subject" 
          name="subject" 
          value="<%= formData.subject || '' %>"
          placeholder="<%= typeof t !== 'undefined' ? t.contact.subject_placeholder : 'Nhập tiêu đề' %>"
          class="<%= errors.subject ? 'input-error' : '' %>"
        >
        <% if (errors.subject) { %>
          <span class="error-text"><%= errors.subject %></span>
        <% } %>
      </div>

      <div class="form-group">
        <label for="phone"><%= typeof t !== 'undefined' ? t.contact.phone : 'Số điện thoại' %></label>
        <input 
          type="tel" 
          id="phone" 
          name="phone" 
          value="<%= formData.phone || '' %>"
          placeholder="<%= typeof t !== 'undefined' ? t.contact.phone_placeholder : 'Nhập số điện thoại' %>"
        >
      </div>
    </div>

    <!-- Nội dung - Full width textarea -->
    <div class="form-group full-width">
      <label for="message"><%= typeof t !== 'undefined' ? t.contact.message : 'Nội dung gửi' %> *</label>
      <textarea 
        id="message" 
        name="message" 
        rows="6"
        placeholder="<%= typeof t !== 'undefined' ? t.contact.message_placeholder : 'Nhập nội dung bạn muốn gửi...' %>"
        class="<%= errors.message ? 'input-error' : '' %>"
      ><%= formData.message || '' %></textarea>
      <% if (errors.message) { %>
        <span class="error-text"><%= errors.message %></span>
      <% } %>
    </div>

    <!-- Submit button -->
    <div class="form-actions">
      <button type="submit" class="btn-submit">
        <%= typeof t !== 'undefined' ? t.contact.submit : 'Gửi liên hệ' %>
      </button>
    </div>
  </form>
</div>

<%- include('../partials/mpc-footer') %>
