<%- include('../partials/mpc-header') %>

<div class="page-container">
<h1><%= t.documents.title %></h1>

<% if (documents && documents.length > 0) { %>
  <div class="document-grid">
    <% documents.forEach(doc => { %>
      <div class="document-card">
        <div class="doc-icon-large">📄</div>
        <h3><%= doc.title %></h3>
        <% if (doc.description) { %>
          <p><%= doc.description %></p>
        <% } %>
        <p class="doc-meta">
          <small><%= t.posts.published_on %> <%= new Date(doc.created_at).toLocaleDateString(lang === 'en' ? 'en-US' : 'vi-VN') %></small>
        </p>
        <a href="/documents/<%= doc.id %>/download" class="btn"><%= t.documents.download_pdf %></a>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <p class="empty-state"><%= t.documents.empty %></p>
<% } %>

</div>

<%- include('../partials/mpc-footer') %>
