<%- include('../partials/header') %>

<section class="hero">
  <h1>Chào mừng đến với Mini CMS</h1>
  <p>Hệ thống quản lý nội dung đơn giản cho doanh nghiệp nhỏ</p>
</section>

<section class="section">
  <h2>Bài viết mới nhất</h2>
  <% if (posts && posts.length > 0) { %>
    <div class="post-grid">
      <% posts.forEach(post => { %>
        <article class="post-card">
          <% if (post.thumbnail) { %>
            <img src="<%= post.thumbnail %>" alt="<%= post.title %>" class="post-thumbnail">
          <% } else { %>
            <div class="post-thumbnail-placeholder"></div>
          <% } %>
          <div class="post-card-content">
            <h3><a href="/posts/<%= post.slug %>"><%= post.title %></a></h3>
            <% if (post.excerpt) { %>
              <p><%= post.excerpt.substring(0, 150) %><%= post.excerpt.length > 150 ? '...' : '' %></p>
            <% } %>
            <small><%= new Date(post.created_at).toLocaleDateString('vi-VN') %></small>
          </div>
        </article>
      <% }) %>
    </div>
    <p class="text-center mt-2">
      <a href="/posts" class="btn">Xem tất cả bài viết →</a>
    </p>
  <% } else { %>
    <p class="empty-state">Chưa có bài viết nào.</p>
  <% } %>
</section>

<section class="section">
  <h2>Tài liệu mới nhất</h2>
  <% if (documents && documents.length > 0) { %>
    <ul class="document-list">
      <% documents.forEach(doc => { %>
        <li class="document-item">
          <span class="doc-icon">📄</span>
          <div class="doc-info">
            <strong><%= doc.title %></strong>
            <% if (doc.description) { %>
              <p><%= doc.description %></p>
            <% } %>
          </div>
          <a href="/documents/<%= doc.id %>/download" class="btn btn-small">Tải xuống</a>
        </li>
      <% }) %>
    </ul>
    <p class="text-center mt-2">
      <a href="/documents" class="btn">Xem tất cả tài liệu →</a>
    </p>
  <% } else { %>
    <p class="empty-state">Chưa có tài liệu nào.</p>
  <% } %>
</section>

<%- include('../partials/footer') %>
