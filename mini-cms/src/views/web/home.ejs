<%- include('../partials/mpc-header') %>

    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-overlay"></div>
      <img src="/uploads/images/Trang%20ch%E1%BB%A7/home-banner.png" alt="Port Hero">
    </section>

    <!-- Quick Nav -->
    <div class="nav-bar">
      <a href="https://eport.mpcport.com/" class="nav-option" target="_blank" rel="noopener noreferrer">
        <img src="/images/icons/icon-eport.svg" alt="E-Port">
        EPORT
      </a>
      <a href="https://cangvuhaiphong.gov.vn/ke-hoach-tau/" class="nav-option" target="_blank" rel="noopener noreferrer">
        <img src="/images/icons/icon-lich-tau.svg" alt="<%= t.landing.ship_schedule %>">
        <%= t.landing.ship_schedule %>
      </a>
      <a href="#" class="nav-option">
        <img src="/images/icons/icon-container.svg" alt="<%= t.landing.container_tracking %>">
        <%= t.landing.container_tracking %>
      </a>
      <a href="#" class="nav-option">
        <img src="/images/icons/icon-hddt.svg" alt="<%= t.landing.invoice_lookup %>">
        <%= t.landing.invoice_lookup %>
      </a>
    </div>

    <!-- About Section -->
    <section class="about-section">
      <div class="about-container">
        <div class="about-left">
          <img src="/images/icons/icon-redline.svg" alt="">
          <div class="about-label"><%= t.landing.about_label %></div>
          <h2 class="about-title"><%= t.landing.about_title %></h2>
        </div>
        <div class="about-right">
          <div class="about-text">
            <%- t.landing.about_text %>
          </div>
          <a class="btn-outline" href="#"><%= t.common.learn_more %>
            <span class="read-more-icon"><img src="/images/icons/icon-arrow-right-red.svg" alt="Arrow"></span>
          </a>
        </div>
      </div>
    </section>

    <!-- Brand Partner Carousel -->
    <section class="brand-carousel-section">
      <div class="container">
        <div class="brand-carousel-wrapper">
          <div class="brand-track-outer">
            <div class="brand-track" id="brandTrack">
              <div class="brand-item"><img src="/images/logo_company/COSCOCS_logo.png" alt="COSCO Shipping"></div>
              <div class="brand-item"><img src="/images/logo_company/HapagLloyd_logo.jpg" alt="Hapag-Lloyd"></div>
              <div class="brand-item"><img src="/images/logo_company/OOCL_logo.png" alt="OOCL"></div>
              <div class="brand-item"><img src="/images/logo_company/PIL_logo.png" alt="PIL"></div>
              <div class="brand-item"><img src="/images/logo_company/Vinfast_logo.png" alt="VinFast"></div>
              <div class="brand-item"><img src="/images/logo_company/ckline_logo.jpg" alt="CK Line"></div>
              <div class="brand-item"><img src="/images/logo_company/cmacgm_logo.png" alt="CMA CGM"></div>
              <div class="brand-item"><img src="/images/logo_company/one_logo.webp" alt="ONE"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- GEO SECTION -->
    <section class="geo-section">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-12 text-center">
            <h3 class="title1">
              <img src="/images/icons/icon-redline.svg" alt="">
            </h3>
            <h2 class="title2"><%= t.landing.geo_title %></h2>
          </div>
          <!-- MAP -->
          <div class="col-lg-6 map-wrapper">
            <img src="/images/map-vietnam.svg" alt="<%= t.landing.view_map %>" class="map-svg">
          </div>
          <!-- CONTENT -->
          <div class="col-lg-6 content-wrapper">
            <div class="info-grid">
              <div class="info-item">
                <div class="icon"><img src="/images/icons/icon-geo-coordinates.svg" alt="Coordinates"></div>
                <div>20&deg; 49' 30" N<br>106&deg; 48' 18" E</div>
              </div>
              <div class="info-item">
                <div class="icon"><img src="/images/icons/icon-geo-area.svg" alt="Area"></div>
                <div>Area:<br>22.3ha</div>
              </div>
              <div class="info-item">
                <div class="icon"><img src="/images/icons/icon-geo-storage.svg" alt="Storage"></div>
                <div>Full Storage Capacity:<br>~13,000 Teus</div>
              </div>
              <div class="info-item">
                <div class="icon"><img src="/images/icons/icon-geo-depth.svg" alt="Depth"></div>
                <div>Depth alongside:<br> -9.7m to -11m</div>
              </div>
              <div class="info-item">
                <div class="icon"><img src="/images/icons/icon-geo-turning.svg" alt="Turning Basin"></div>
                <div>Turning Basin:<br>360m</div>
              </div>
              <div class="info-item">
                <div class="icon"><img src="/images/icons/icon-geo-berth.svg" alt="Berth"></div>
                <div>Berth:<br>02 Unit 380m<br>Length</div>
              </div>
            </div>

            <p class="description"><%= t.landing.geo_description %></p>

            <a class="btn-outline btn-outline--mt" href="#"><%= t.landing.view_map %>
              <span class="map-more-icon"><img src="/images/icons/icon-arrow-right-red.svg" alt="Arrow"></span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FACILITY SECTION -->
    <section class="facility py-5">
      <div class="container-fluid">
        <div class="text-center mb-5">
          <h3 class="title1"><img src="/images/icons/icon-redline.svg" alt=""></h3>
          <h2 class="title2"><%= t.landing.facility_title %></h2>
        </div>

        <div class="row align-items-center">
          <!-- LEFT PANEL -->
          <div class="col-lg-6 facility-left text-white">
            <div class="row">
              <div class="col-md-4">
                <div class="facility-tabs flex-column align-items-end text-end">
                  <span class="tab-item active" data-tab="tab1"><%= t.landing.tab_infrastructure %></span>
                  <span class="tab-item" data-tab="tab5"><%= t.landing.tab_it %></span>
                  <span class="tab-item" data-tab="tab2"><%= t.landing.tab_capacity %></span>
                  <span class="tab-item" data-tab="tab4"><%= t.landing.tab_equipment %></span>
                  <span class="tab-item" data-tab="tab6"><%= t.landing.tab_warehouse %></span>
                  <span class="tab-item" data-tab="tab3"><%= t.landing.tab_structure %></span>
                </div>
              </div>
              <div class="col-md-8 facility-col-left">
                <div id="tab-content">
                  <div class="tab-pane active" id="tab1">
                    <ul>
                      <li>Tổng diện tích toàn cảng: 22.3 ha.</li>
                      <li>Khu vực xếp container: 13,200 teus.</li>
                      <li>Khu vực xếp hàng OOG, DG.</li>
                      <li>Khu vực container lạnh: 432 ổ cắm.</li>
                      <li>Kho CFS: 10,000 m2.</li>
                      <li>Khu vực sửa chữa container: 1,200 m2.</li>
                      <li>Khu vực soi chiếu container.</li>
                      <li>Cổng: 10 làn.</li>
                      <li>Cân điện tử 120 tấn: 02.</li>
                    </ul>
                  </div>
                  <div class="tab-pane" id="tab5">
                    <ul>
                      <li>Hệ thống quản lý cảng TOS.</li>
                      <li>Cổng tự động nhận dạng container.</li>
                      <li>Hệ thống camera giám sát 24/7.</li>
                    </ul>
                  </div>
                  <div class="tab-pane" id="tab2">
                    <ul>
                      <li>Tàu container đến 50,000 DWT.</li>
                      <li>Công suất thiết kế: 500,000 TEU/năm.</li>
                    </ul>
                  </div>
                  <div class="tab-pane" id="tab4">
                    <ul>
                      <li>Cẩu bờ STS: 02 chiếc.</li>
                      <li>Cẩu bãi RTG: 06 chiếc.</li>
                      <li>Xe nâng Reach Stacker: 04 chiếc.</li>
                      <li>Đầu kéo: 12 chiếc.</li>
                    </ul>
                  </div>
                  <div class="tab-pane" id="tab6">
                    <ul>
                      <li>Bãi container: 13,200 TEU.</li>
                      <li>Kho CFS: 10,000 m2.</li>
                    </ul>
                  </div>
                  <div class="tab-pane" id="tab3">
                    <ul>
                      <li>Chiều dài cầu cảng: 380m.</li>
                      <li>Độ sâu trước bến: -9.7m đến -11m.</li>
                      <li>Vũng quay trở tàu: 360m.</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <div class="facility-bottom-content text-center mt-5">
              <a class="btn-outline btn-outline--white" href="#">
                <%= t.common.learn_more %>
                <span class="read-more-icon"><img src="/images/icons/icon-arrow-right-white.svg" width="41" height="41" alt="Arrow"></span>
              </a>
              <div class="thumbs mt-4">
                <img src="/uploads/images/Trang%20ch%E1%BB%A7/facility-img1.png" class="thumb active" data-index="0">
                <img src="/uploads/images/Trang%20ch%E1%BB%A7/facility-img2.png" class="thumb" data-index="1">
                <img src="/uploads/images/Trang%20ch%E1%BB%A7/facility-img3.png" class="thumb" data-index="2">
                <img src="/uploads/images/Trang%20ch%E1%BB%A7/facility-img4.png" class="thumb" data-index="3">
              </div>
            </div>
          </div>

          <!-- RIGHT IMAGE -->
          <div class="col-lg-6 facility-image">
            <div class="image-wrapper">
              <img id="mainImage" src="/uploads/images/Trang%20ch%E1%BB%A7/facility-img5.png" class="img-fluid" />
              <button class="next-btn-service"><img src="/images/icons/icon-arrow-right-dark.svg" width="41" height="41" alt="Next"></button>
            </div>
          </div>
        </div>
      </div>
    </section>

