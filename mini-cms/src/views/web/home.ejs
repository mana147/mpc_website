<%- include('../partials/header') %>

<section class="hero">
  <h1><%= t.home.welcome %></h1>
  <p><%= t.home.description %></p>
</section>

<section class="section">
  <h2><%= t.home.latest_posts %></h2>
  <% if (posts && posts.length > 0) { %>
    <div class="post-grid">
      <% posts.forEach(post => { %>
        <%
          const displayTitle = (lang === 'en' && post.title_en) ? post.title_en : post.title;
          const displayExcerpt = (lang === 'en' && post.excerpt_en) ? post.excerpt_en : post.excerpt;
        %>
        <article class="post-card">
          <% if (post.thumbnail) { %>
            <img src="<%= post.thumbnail %>" alt="<%= displayTitle %>" class="post-thumbnail">
          <% } else { %>
            <div class="post-thumbnail-placeholder"></div>
          <% } %>
          <div class="post-card-content">
            <h3><a href="/posts/<%= post.slug %>"><%= displayTitle %></a></h3>
            <% if (displayExcerpt) { %>
              <p><%= displayExcerpt.substring(0, 150) %><%= displayExcerpt.length > 150 ? '...' : '' %></p>
            <% } %>
            <small><%= new Date(post.created_at).toLocaleDateString(lang === 'en' ? 'en-US' : 'vi-VN') %></small>
          </div>
        </article>
      <% }) %>
    </div>
    <p class="text-center mt-2">
      <a href="/posts" class="btn"><%= t.home.view_all_posts %></a>
    </p>
  <% } else { %>
    <p class="empty-state"><%= t.posts.empty %></p>
  <% } %>
</section>

<section class="section">
  <h2><%= t.home.latest_documents %></h2>
  <% if (documents && documents.length > 0) { %>
    <ul class="document-list">
      <% documents.forEach(doc => { %>
        <li class="document-item">
          <span class="doc-icon">📄</span>
          <div class="doc-info">
            <strong><%= doc.title %></strong>
            <% if (doc.description) { %>
              <p><%= doc.description %></p>
            <% } %>
          </div>
          <a href="/documents/<%= doc.id %>/download" class="btn btn-small"><%= t.documents.download %></a>
        </li>
      <% }) %>
    </ul>
    <p class="text-center mt-2">
      <a href="/documents" class="btn"><%= t.home.view_all_documents %></a>
    </p>
  <% } else { %>
    <p class="empty-state"><%= t.documents.empty %></p>
  <% } %>
</section>

<%- include('../partials/footer') %>
