    <!-- IMAGES LIBRARY -->
    <section class="gallery-section">
      <div class="container-fluid">
        <div class="text-center gallery-title">
          <h3 class="title1"><img src="/images/icons/icon-redline.svg" alt=""></h3>
          <h2 class="title2"><%= t.landing.gallery_title %></h2>
          <a href="/gallery" class="more-link"><%= t.common.learn_more %></a>
        </div>

        <div class="row g-3 mt-4">
          <!-- Part 1 -->
          <div class="col-lg-4">
            <div class="img-box big">
              <% if (galleryImages && galleryImages.length > 0) { %>
                <img src="<%= galleryImages[0].filepath %>" class="img-fluid" alt="<%= galleryImages[0].alt_text || '' %>">
              <% } else { %>
                <img src="/uploads/images/Trang%20ch%E1%BB%A7/library-img1.png" class="img-fluid" alt="">
              <% } %>
            </div>
          </div>

          <!-- Part 2 -->
          <div class="col-lg-4">
            <div class="row g-3">
              <% for (let i = 1; i <= 4; i++) { %>
                <div class="col-6">
                  <div class="img-box small">
                    <% if (galleryImages && galleryImages.length > i) { %>
                      <img src="<%= galleryImages[i].filepath %>" class="img-fluid" alt="<%= galleryImages[i].alt_text || '' %>">
                    <% } else { %>
                      <img src="/uploads/images/Trang%20ch%E1%BB%A7/service-img<%= i %>.png" class="img-fluid" alt="">
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Part 3 -->
          <div class="col-lg-4">
            <div class="img-box big slider">
              <% if (galleryImages && galleryImages.length > 5) { %>
                <img id="sliderImage" src="<%= galleryImages[5].filepath %>" class="img-fluid" alt="">
              <% } else { %>
                <img id="sliderImage" src="/uploads/images/Trang%20ch%E1%BB%A7/ha-tang.png" class="img-fluid" alt="">
              <% } %>
              <button class="next-btn" onclick="nextSlide()"><img src="/images/icons/icon-gallery-play.svg" alt="Play"></button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- NEWS AND EVENT -->
    <section class="news-section py-5">
      <div class="container text-center">
        <h3 class="title1"><img src="/images/icons/icon-redline.svg" alt=""></h3>
        <h2 class="news-title"><%= t.landing.news_title %></h2>
        <a href="/posts" class="more-link"><%= t.common.learn_more %></a>

        <div class="news-wrapper mt-4">
          <!-- LEFT -->
          <div class="news-left">
            <ul class="news-list text-start">
              <% if (posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                  <%
                    const displayTitle = (lang === 'en' && post.title_en) ? post.title_en : post.title;
                  %>
                  <li>
                    <a href="/posts/<%= post.slug %>"><%= displayTitle.length > 60 ? displayTitle.substring(0, 60) + '...' : displayTitle %></a>
                    <span class="date"><%= new Date(post.created_at).toLocaleDateString('vi-VN') %></span>
                  </li>
                <% }) %>
              <% } else { %>
                <li><%= t.posts.empty %></li>
              <% } %>
            </ul>
          </div>

          <!-- RIGHT -->
          <div class="news-right">
            <% if (posts && posts.length > 0 && posts[0].thumbnail) { %>
              <img src="<%= posts[0].thumbnail %>" alt="<%= posts[0].title %>">
            <% } else { %>
              <img src="/uploads/images/Trang%20ch%E1%BB%A7/event-img1.png" alt="Event">
            <% } %>
          </div>
        </div>
      </div>
    </section>

