<%- include('../partials/mpc-header') %>

<div class="page-container">

<%
  // Chọn nội dung theo ngôn ngữ
  const displayTitle = (lang === 'en' && post.title_en) ? post.title_en : post.title;
  const displayExcerpt = (lang === 'en' && post.excerpt_en) ? post.excerpt_en : post.excerpt;
  const displayContent = (lang === 'en' && post.content_en) ? post.content_en : post.content;
  const dateLocale = lang === 'en' ? 'en-US' : 'vi-VN';
%>

<article class="post-detail">
  <header class="post-header">
    <h1><%= displayTitle %></h1>
    <p class="post-meta">
      <%= t.posts.published_on %> <%= new Date(post.created_at).toLocaleDateString(dateLocale) %>
      <% if (post.updated_at && post.updated_at !== post.created_at) { %>
        | <%= t.posts.updated_on %> <%= new Date(post.updated_at).toLocaleDateString(dateLocale) %>
      <% } %>
    </p>
  </header>

  <% if (post.thumbnail) { %>
    <img src="<%= post.thumbnail %>" alt="<%= displayTitle %>" class="post-featured-image">
  <% } %>

  <% if (displayExcerpt) { %>
    <p class="post-excerpt"><%= displayExcerpt %></p>
  <% } %>

  <div class="post-content">
    <%- displayContent.replace(/\n/g, '<br>') %>
  </div>

  <footer class="post-footer">
    <a href="/posts" class="btn"><%= t.posts.back_to_list %></a>
  </footer>
</article>

</div>

<%- include('../partials/mpc-footer') %>
