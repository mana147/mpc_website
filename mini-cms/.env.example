# ============================================================
# MPC Mini CMS — Environment Variables
# Sao chép file này thành .env và điền giá trị thực
# ============================================================

# Server
PORT=3000
NODE_ENV=development   # production | development

# Session Secret — BẮT BUỘC thay đổi trong production
# Tạo giá trị ngẫu nhiên bằng lệnh:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Tài khoản Admin mặc định
# Chỉ dùng khi khởi tạo database lần đầu (INSERT chỉ chạy nếu chưa có user)
# SAU KHI CHẠY LẦN ĐẦU: đổi mật khẩu ngay tại admin panel hoặc xóa 2 dòng này
ADMIN_USERNAME=admin
ADMIN_PASSWORD=        # KHÔNG để trống, KHÔNG dùng admin123
